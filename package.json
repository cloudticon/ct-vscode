{
  "name": "cloudticon-ct",
  "displayName": "Cloudticon",
  "description": "TypeScript support for .ct (Cloudticon Template) files with URL imports and Values injection",
  "version": "0.0.2",
  "publisher": "cloudticon",
  "license": "MIT",
  "preview": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/cloudticon/ct-vscode"
  },
  "homepage": "https://github.com/cloudticon/ct",
  "bugs": {
    "url": "https://github.com/cloudticon/ct-vscode/issues"
  },
  "keywords": [
    "kubernetes",
    "k8s",
    "cloudticon",
    "ct",
    "manifests",
    "typescript",
    "devops",
    "infrastructure-as-code"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:ct",
    "workspaceContains:**/*.ct"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ct",
        "extensions": [
          ".ct"
        ],
        "aliases": [
          "Cloudticon Template",
          "ct"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "typescriptServerPlugins": [
      {
        "name": "ct-typescript-plugin",
        "enableForWorkspaceTypeScriptVersions": true
      }
    ]
  },
  "scripts": {
    "compile": "node build.mjs",
    "watch": "node build.mjs --watch",
    "package": "npm run compile && vsce package --allow-missing-repository",
    "test": "vitest run"
  },
  "dependencies": {
    "@vscode/vsce": "^3.7.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.2"
  }
}
